---
import { render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSpecEntryByTranslationKey } from "@utils/content-utils";
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, normalizeLocale } from "@utils/locale-utils";

export async function getStaticPaths() {
	return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const currentLocale = normalizeLocale(Astro.params.lang || DEFAULT_LOCALE);
const aboutPost = await getSpecEntryByTranslationKey("about", currentLocale);

if (!aboutPost) {
	throw new Error(`About page content not found for locale ${currentLocale}`);
}

const { Content } = await render(aboutPost);
---

<MainGridLayout title={i18n(I18nKey.about, currentLocale)} description={i18n(I18nKey.about, currentLocale)} lang={currentLocale} disableEntranceAnimations={true}>
    <h1 class="sr-only">{i18n(I18nKey.about, currentLocale)}</h1>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>