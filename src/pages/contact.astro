---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---
<MainGridLayout title="Contact Us" description="Get in touch with Tadawi Life Tech" disableEntranceAnimations={true}>
    <div class="w-full flex flex-col gap-4">

        <!-- Header -->
        <div class="card-base px-6 py-6 text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-[var(--primary)]" data-i18n="contactTitle">Contact Us</h1>
        </div>

        <!-- Info Boxes Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

            <!-- Email -->
            <div class="card-base p-5 flex flex-col items-center text-center gap-3 group hover:shadow-lg transition-shadow">
                <div class="w-12 h-12 rounded-2xl bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-[var(--btn-content)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="font-semibold text-sm text-50 uppercase tracking-wider" data-i18n="contactEmail">Email</h3>
                <a href="mailto:info@tadawilifetech.com" class="text-[var(--primary)] hover:underline text-sm break-all" dir="ltr">info@tadawilifetech.com</a>
            </div>

            <!-- Phone -->
            <div class="card-base p-5 flex flex-col items-center text-center gap-3 group hover:shadow-lg transition-shadow">
                <div class="w-12 h-12 rounded-2xl bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-[var(--btn-content)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <h3 class="font-semibold text-sm text-50 uppercase tracking-wider" data-i18n="contactPhone">Phone</h3>
                <a href="tel:+96891235160" class="text-[var(--primary)] hover:underline text-sm" dir="ltr">+968 91235160</a>
            </div>

            <!-- Working Hours -->
            <div class="card-base p-5 flex flex-col items-center text-center gap-3 group hover:shadow-lg transition-shadow">
                <div class="w-12 h-12 rounded-2xl bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-[var(--btn-content)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <h3 class="font-semibold text-sm text-50 uppercase tracking-wider" data-i18n="contactHours">Working Hours</h3>
                <p class="text-90 text-sm" dir="ltr">9:00 – 13:00 &amp; 16:00 – 19:00</p>
            </div>

            <!-- Instagram -->
            <div class="card-base p-5 flex flex-col items-center text-center gap-3 group hover:shadow-lg transition-shadow">
                <div class="w-12 h-12 rounded-2xl bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-[var(--btn-content)] group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </div>
                <h3 class="font-semibold text-sm text-50 uppercase tracking-wider" data-i18n="contactInstagram">Instagram</h3>
                <div class="flex flex-col gap-1">
                    <a href="https://instagram.com/Ortino_arabic" target="_blank" rel="noopener noreferrer" class="text-[var(--primary)] hover:underline text-sm" dir="ltr">@Ortino_arabic</a>
                    <a href="https://instagram.com/sleeptimecare.oman" target="_blank" rel="noopener noreferrer" class="text-[var(--primary)] hover:underline text-sm" dir="ltr">@sleeptimecare.oman</a>
                </div>
            </div>

        </div>

        <!-- Address Full Width -->
        <div class="card-base p-5 flex items-center gap-4 group hover:shadow-lg transition-shadow">
            <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-[var(--btn-regular-bg)] group-hover:bg-[var(--primary)] flex items-center justify-center transition-colors">
                <svg class="w-5 h-5 text-[var(--btn-content)] group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
                <h3 class="font-semibold text-sm text-50 uppercase tracking-wider mb-0.5" data-i18n="contactAddress">Address</h3>
                <p class="text-90">Al Ghubrah, Muscat, Oman</p>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="card-base px-6 md:px-10 py-8 md:py-10">
            <h2 class="text-xl font-bold text-90 mb-6" data-i18n="contactFormTitle">Send us a message</h2>
            <form id="contact-form" class="flex flex-col gap-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label for="cf-name" class="block text-sm font-medium text-75 mb-1.5" data-i18n="contactName">Full Name</label>
                        <input type="text" id="cf-name" name="name" required
                            class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] text-90 placeholder:text-30 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] transition"
                            data-i18n-placeholder="contactNamePh" placeholder="Your name" />
                    </div>
                    <div>
                        <label for="cf-email" class="block text-sm font-medium text-75 mb-1.5" data-i18n="contactEmailLabel">Email</label>
                        <input type="email" id="cf-email" name="email" required
                            class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] text-90 placeholder:text-30 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] transition"
                            dir="ltr" placeholder="your@email.com" />
                    </div>
                </div>
                <div>
                    <label for="cf-phone" class="block text-sm font-medium text-75 mb-1.5" data-i18n="contactPhoneLabel">Phone Number</label>
                    <input type="tel" id="cf-phone" name="phone"
                        class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] text-90 placeholder:text-30 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] transition"
                        dir="ltr" placeholder="+968 ..." />
                </div>
                <div>
                    <label for="cf-subject" class="block text-sm font-medium text-75 mb-1.5" data-i18n="contactSubject">Subject</label>
                    <input type="text" id="cf-subject" name="subject" required
                        class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] text-90 placeholder:text-30 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] transition"
                        data-i18n-placeholder="contactSubjectPh" placeholder="How can we help?" />
                </div>
                <div>
                    <label for="cf-message" class="block text-sm font-medium text-75 mb-1.5" data-i18n="contactMessage">Message</label>
                    <textarea id="cf-message" name="message" rows="5" required
                        class="w-full px-4 py-3 rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] text-90 placeholder:text-30 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] transition resize-y"
                        data-i18n-placeholder="contactMessagePh" placeholder="Write your message..."></textarea>
                </div>
                <button type="submit" id="cf-submit"
                    class="self-start px-8 py-3 rounded-xl bg-[var(--primary)] text-white font-semibold text-base hover:opacity-90 active:scale-[0.98] transition-all duration-150 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    <span data-i18n="contactSend">Send via WhatsApp</span>
                </button>
            </form>
        </div>

    </div>

    <script is:inline>
        (function() {
            var translations = {
                en: {
                    contactTitle: 'Contact Us',
                    contactEmail: 'Email',
                    contactPhone: 'Phone',
                    contactHours: 'Working Hours',
                    contactInstagram: 'Instagram',
                    contactAddress: 'Address',
                    contactFormTitle: 'Send us a message',
                    contactName: 'Full Name',
                    contactNamePh: 'Your name',
                    contactEmailLabel: 'Email',
                    contactPhoneLabel: 'Phone Number',
                    contactSubject: 'Subject',
                    contactSubjectPh: 'How can we help?',
                    contactMessage: 'Message',
                    contactMessagePh: 'Write your message...',
                    contactSend: 'Send via WhatsApp'
                },
                ar: {
                    contactTitle: 'اتصل بنا',
                    contactEmail: 'البريد الإلكتروني',
                    contactPhone: 'الهاتف',
                    contactHours: 'ساعات العمل',
                    contactInstagram: 'انستغرام',
                    contactAddress: 'العنوان',
                    contactFormTitle: 'أرسل لنا رسالة',
                    contactName: 'الاسم الكامل',
                    contactNamePh: 'اسمك',
                    contactEmailLabel: 'البريد الإلكتروني',
                    contactPhoneLabel: 'رقم الهاتف',
                    contactSubject: 'الموضوع',
                    contactSubjectPh: 'كيف يمكننا مساعدتك؟',
                    contactMessage: 'الرسالة',
                    contactMessagePh: 'اكتب رسالتك...',
                    contactSend: 'أرسل عبر واتساب'
                }
            };

            function applyContactTranslations() {
                var lang = localStorage.getItem('lang') || 'en';
                var t = translations[lang] || translations.en;
                document.querySelectorAll('[data-i18n]').forEach(function(el) {
                    var key = el.getAttribute('data-i18n');
                    if (t[key]) el.textContent = t[key];
                });
                document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
                    var key = el.getAttribute('data-i18n-placeholder');
                    if (t[key]) el.setAttribute('placeholder', t[key]);
                });
            }

            applyContactTranslations();
            window.addEventListener('storage', function(e) {
                if (e.key === 'lang') applyContactTranslations();
            });
            var langObserver = new MutationObserver(function() { applyContactTranslations(); });
            langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
        })();

        document.getElementById('contact-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var name = document.getElementById('cf-name').value.trim();
            var email = document.getElementById('cf-email').value.trim();
            var phone = document.getElementById('cf-phone').value.trim();
            var subject = document.getElementById('cf-subject').value.trim();
            var message = document.getElementById('cf-message').value.trim();

            var text = '*New Contact Message*\n\n'
                + '*Name:* ' + name + '\n'
                + '*Email:* ' + email + '\n'
                + (phone ? '*Phone:* ' + phone + '\n' : '')
                + '*Subject:* ' + subject + '\n\n'
                + '*Message:*\n' + message;

            var whatsappUrl = 'https://api.whatsapp.com/send?phone=96891235160&text=' + encodeURIComponent(text);
            window.open(whatsappUrl, '_blank', 'noopener,noreferrer');
        });
    </script>
</MainGridLayout>
