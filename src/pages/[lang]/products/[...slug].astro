---
import path from "node:path";
import { getCollection } from "astro:content";
import AddToCartButton from "@components/AddToCartButton";
import Markdown from "@components/misc/Markdown.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { DEFAULT_LOCALE, getEntryTranslationKey, normalizeLocale } from "@utils/locale-utils";
import { getDir, getProductUrlBySlug } from "@utils/url-utils";

export async function getStaticPaths() {
	const entries = await getCollection("products", ({ data }) => import.meta.env.PROD ? data.draft !== true : true);
	return entries.map((entry) => ({
		params: { lang: normalizeLocale(entry.data.lang), slug: getEntryTranslationKey(entry) },
		props: { entry },
	}));
}

const currentLocale = normalizeLocale(Astro.params.lang || DEFAULT_LOCALE);
const { entry } = Astro.props;
const { Content } = await entry.render();
const productKey = getEntryTranslationKey(entry);
const productUrl = getProductUrlBySlug(productKey, currentLocale);
const siteOrigin = Astro.site?.origin || "https://tadawilifetech.com";
const ogImageAbsolute = entry.data.image ? `${siteOrigin}${entry.data.image.startsWith("/") ? "" : "/"}${entry.data.image}` : undefined;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Product",
	name: entry.data.title,
	description: entry.data.description || entry.data.title,
	image: ogImageAbsolute,
	url: `${siteOrigin}${productUrl}`,
	brand: {
		"@type": "Organization",
		name: "Tadawi Life Tech",
	},
	offers: entry.data.price ? {
		"@type": "Offer",
		price: entry.data.price,
		availability: "https://schema.org/InStock",
	} : undefined,
};
---

<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={currentLocale} ogImage={entry.data.image}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div data-pagefind-body class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
            <div class="relative onload-animation">
                <h1 data-pagefind-meta="title" class="transition w-full block font-bold mb-3 text-3xl md:text-[2.25rem]/[2.75rem] text-black/90 dark:text-white/90 md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)] before:absolute before:top-[0.75rem] ltr:before:left-[-1.125rem] rtl:before:right-[-1.125rem]">
                    {entry.data.title}
                </h1>
            </div>

            {entry.data.price && <div class="text-lg font-semibold text-[var(--primary)] mb-4 onload-animation">{entry.data.price}</div>}

            {entry.data.image && <ImageWrapper src={entry.data.image} basePath={path.join("content/products/", getDir(entry.id))} class="mb-8 rounded-xl banner-container onload-animation"/>}

            <Markdown class="mb-6 markdown-content onload-animation">
                <Content />
            </Markdown>

            <AddToCartButton
                client:load
                id={productKey}
                title={entry.data.title}
                price={entry.data.price}
                url={productUrl}
                locale={currentLocale}
            />
        </div>
    </div>
</MainGridLayout>
