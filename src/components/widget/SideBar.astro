---
import type { MarkdownHeading } from "astro";
import Categories from "./Categories.astro";
import ProductCategories from "./ProductCategories.astro";
import ProductTags from "./ProductTags.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
	disableEntranceAnimations?: boolean;
}

const className = Astro.props.class;
const disableEntranceAnimations = Astro.props.disableEntranceAnimations ?? false;
---
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class:list={[
        "flex flex-col w-full gap-4 top-4 sticky top-4",
        {"transition-all duration-700": !disableEntranceAnimations},
    ]}>
        <ProductCategories class:list={{"onload-animation": !disableEntranceAnimations}} style={disableEntranceAnimations ? undefined : "animation-delay: 150ms"}></ProductCategories>
        <ProductTags class:list={{"onload-animation": !disableEntranceAnimations}} style={disableEntranceAnimations ? undefined : "animation-delay: 165ms"}></ProductTags>
        <Categories class:list={{"onload-animation": !disableEntranceAnimations}} style={disableEntranceAnimations ? undefined : "animation-delay: 175ms"}></Categories>
        <Tag class:list={{"onload-animation": !disableEntranceAnimations}} style={disableEntranceAnimations ? undefined : "animation-delay: 200ms"}></Tag>
    </div>
</div>
