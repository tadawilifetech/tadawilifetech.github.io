---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getProductTagList } from "../../utils/content-utils";
import { getLocaleFromPathname } from "../../utils/locale-utils";
import { getProductTagUrl } from "../../utils/url-utils";
import ButtonTag from "../control/ButtonTag.astro";
import WidgetLayout from "./WidgetLayout.astro";

const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const tags = await getProductTagList(currentLocale);

const COLLAPSED_HEIGHT = "7.5rem";

const isCollapsed = tags.length >= 20;

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---
<WidgetLayout name={i18n(I18nKey.productTags)} id="product-tags" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT} class={className} style={style} dataI18n="productTags">
    <div class="flex gap-2 flex-wrap">
        {tags.map(t => (
            <ButtonTag href={getProductTagUrl(t.name, currentLocale)} label={t.name.trim()}>
                {t.name.trim()}
            </ButtonTag>
        ))}
    </div>
</WidgetLayout>
