---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import OurBrandCarousel from "../components/OurBrandCarousel";
import ProductCard from "../components/ProductCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedProducts } from "../utils/content-utils";
import { getProductUrlBySlug } from "../utils/url-utils";

export const getStaticPaths = (async () => {
	return [
		{
			params: { page: undefined },
			props: {
				products: await getSortedProducts(),
			},
		},
	];
}) satisfies GetStaticPaths;

const { products } = Astro.props as {
	products: CollectionEntry<"products">[];
};
const len = products.length;
---

<MainGridLayout>
    <h1 class="sr-only">Tadawi Life Tech</h1>
    <div id="category-filter-header" class="hidden mb-4 card-base px-6 py-4 rounded-[var(--radius-large)] flex items-center justify-between">
        <span class="font-bold text-lg text-90" id="category-filter-label"></span>
        <a href="/" class="text-sm text-[var(--primary)] hover:underline" id="clear-category-filter">✕</a>
    </div>
    <div class="transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4">
        <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {products.map((entry: CollectionEntry<"products">, i: number) => (
                <ProductCard
                    entry={entry}
                    title={entry.data.title}
                    url={getProductUrlBySlug(entry.slug)}
                    image={entry.data.image}
                    description={entry.data.description}
                    price={entry.data.price}
                    draft={entry.data.draft}
                    class:list="onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${i * 50}ms);`}
                />
            ))}
        </div>
    </div>
    <OurBrandCarousel client:load className="mb-4 onload-animation" animationDelay={`calc(var(--content-delay) + ${len * 50 + 100}ms)`}></OurBrandCarousel>
</MainGridLayout>

<script is:inline>
function filterProductsByCategory() {
    const params = new URLSearchParams(window.location.search);
    const category = params.get('category');
    const header = document.getElementById('category-filter-header');
    const label = document.getElementById('category-filter-label');
    const cards = document.querySelectorAll('[data-product-category]');

    if (category) {
        if (header) header.classList.remove('hidden');
        if (label) label.textContent = category;
        cards.forEach(card => {
            const cardCat = card.getAttribute('data-product-category') || '';
            if (cardCat.trim().toLowerCase() === category.trim().toLowerCase()) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    } else {
        if (header) header.classList.add('hidden');
        cards.forEach(card => { card.style.display = ''; });
    }
}
filterProductsByCategory();
document.addEventListener('swup:contentReplaced', filterProductsByCategory);
</script>
