---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getProductCategoryList } from "../../utils/content-utils";
import { getLocaleFromPathname } from "../../utils/locale-utils";
import { getProductCategoryUrl } from "../../utils/url-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const categories = await getProductCategoryList(currentLocale);

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

const isCollapsed = categories.length >= COLLAPSE_THRESHOLD;

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.productCategories)} id="product-categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style} dataI18n="productCategories"
>
    {categories.map((c) =>
        <ButtonLink
            url={getProductCategoryUrl(c.name, currentLocale)}
            badge={String(c.count)}
            label={`View all products in the ${c.name.trim()} category`}
        >
            {c.name.trim()}
        </ButtonLink>
    )}
</WidgetLayout>
